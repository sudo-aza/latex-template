% ── Geometry ──
\geometry{paper=a4paper, top=30mm, bottom=30mm, left=30mm, right=25mm, headheight=15pt}

% ══════════════════════════════════════════════
%  SECTION HEADINGS — Colored Full-Width Boxes
% ══════════════════════════════════════════════
% \section: full-width dark navy box, white text, subtle right rule
\titleformat{\section}
  {\normalfont\Large\bfseries}
  {}{0pt}
  {\makebox[\linewidth][l]{%
     \colorbox{cSecBoxBg}{%
       \parbox{\dimexpr\linewidth}{%
         \vspace{7pt}%
         \hspace{14pt}%
         \textcolor{cSecBoxFg}{\insertsection}%
         \hfill
         \textcolor{cSecBoxFg!40}{\rule{0.25\linewidth}{0.4pt}}%
         \hspace{14pt}%
         \vspace{7pt}%
       }%
     }%
   }}
  [\vspace{4pt}]

% \subsection: full-width royal blue box, white text, number badge
\titleformat{\subsection}
  {\normalfont\large\bfseries}
  {}{0pt}
  {\makebox[\linewidth][l]{%
     \colorbox{cSubsecBoxBg}{%
       \parbox{\dimexpr\linewidth}{%
         \vspace{6pt}%
         \hspace{14pt}%
         \tikz[baseline=(num.base)]{%
           \node[fill=cSubsecBoxAccent, text=white, rounded corners=2pt,
                 inner xsep=6pt, inner ysep=2pt,
                 font=\footnotesize\bfseries] (num) {\thesubsection};}%
         \hspace{8pt}%
         \textcolor{cSubsecBoxFg}{\insertsubsection}%
         \hfill
         \textcolor{cSubsecBoxFg!30}{\rule{0.20\linewidth}{0.3pt}}%
         \hspace{14pt}%
         \vspace{6pt}%
       }%
     }%
   }}
  [\vspace{3pt}]

% \subsubsection: left accent bar + bold text (no full box — lighter treatment)
\titleformat{\subsubsection}
  {\normalfont\normalsize\bfseries\color{cSubsubheadingFg}}
  {}{0pt}
  {\makebox[\linewidth][l]{%
     \hspace{4pt}%
     \colorbox{cSubsubAccent}{\rule{0pt}{\dimexpr\baselineskip+8pt}}%
     \hspace{-4pt}%
     \hspace{10pt}%
     \insertsubsubsection
   }}
  [\vspace{2pt}]

\titlespacing{\section}{0pt}{26pt plus 4pt minus 2pt}{12pt plus 2pt minus 1pt}
\titlespacing{\subsection}{0pt}{20pt plus 3pt minus 1pt}{8pt plus 1pt minus 1pt}
\titlespacing{\subsubsection}{0pt}{14pt plus 2pt minus 1pt}{6pt}

% ── TOC ──
\renewcommand{\dotfill}{%
  \leavevmode\cleaders\hbox to 1.2em{\hss.\hss}\hfill\kern0pt}

\titlecontents{section}[0pt]
  {\addvspace{14pt}\fontsize{12}{14}\selectfont\bfseries\color{cTocFg}}
  {\thecontentslabel\hspace{10pt}}{}
  {\hspace{0.8em}{\color{cTocDot}\dotfill}\hspace{0.5em}%
   {\fontsize{10}{12}\selectfont\color{cTocDot}\thecontentspage}}
  \addvspace{4pt}
\titlecontents{subsection}[16pt]
  {\addvspace{6pt}\fontsize{11}{13}\selectfont\color{cTocSubFg}}
  {\thecontentslabel\hspace{8pt}}{}
  {\hspace{0.8em}{\color{cTocDot}\dotfill}\hspace{0.5em}%
   {\fontsize{10}{12}\selectfont\color{cTocDot}\thecontentspage}}
  \addvspace{2pt}
\titlecontents{subsubsection}[32pt]
  {\addvspace{3pt}\fontsize{10}{12}\selectfont\color{cMidGray}}{}{}
  {\hspace{0.8em}{\color{cMidGray!50}\dotfill}\hspace{0.5em}%
   {\fontsize{9}{11}\selectfont\color{cMidGray}\thecontentspage}}

% ── Captions ──
\captionsetup{tableposition=top, font=small, labelfont=bf, labelsep=period, skip=8pt, belowskip=6pt}
\captionsetup[lstlisting]{font=small, labelfont=bf, labelsep=period}

% ── Chapter page (theme-aware) ──
\newcommand{\chapterpage}[2]{%
  \clearpage
  \newgeometry{paper=a4paper, top=0pt, bottom=0pt, left=0pt, right=0pt, headheight=0pt}%
  \thispagestyle{empty}%
  \noindent
  \begin{tikzpicture}
    \useasboundingbox (0,0) rectangle (\paperwidth, \paperheight);
    \iftoggle{sudodoc@dark}{%
      % ── DARK chapter page ──
      \fill[cPageBg]
        (0, 0.60\paperheight) rectangle (\paperwidth, \paperheight);
      \fill[cStripeColor]
        (0, 0.60\paperheight) rectangle (5pt, \paperheight);
      \fill[cAccentDeep]
        (0, 0.5975\paperheight) rectangle (\paperwidth, 0.6025\paperheight);
      \node[anchor=east, font=\fontsize{140}{140}\selectfont\bfseries,
            text=cAccent, opacity=0.07]
        at ([xshift=-15pt, yshift=0.80\paperheight]current bounding box.south) {#1};
      \node[anchor=north west]
        at (40pt, 0.88\paperheight)
        {\fontsize{13}{15}\selectfont\color{cMidGray}%
          CHAPTER\hspace{8pt}{\fontsize{18}{20}\selectfont\bfseries\color{cAccentLight}#1}};
      \node[anchor=north west, text width=0.72\paperwidth]
        at (40pt, 0.80\paperheight)
        {\fontsize{30}{36}\selectfont\bfseries\color{cTitleFg}#2};
      \draw[cAccentDeep, line width=2pt]
        (40pt, 0.645\paperheight) -- (0.42\paperwidth, 0.645\paperheight);
    }{%
      % ── LIGHT chapter page ──
      \fill[cAccent]
        (0, 0.60\paperheight) rectangle (\paperwidth, \paperheight);
      \fill[cAccentDeep]
        (0, 0.60\paperheight) rectangle (5pt, \paperheight);
      \fill[cAccent]
        (0, 0.5975\paperheight) rectangle (\paperwidth, 0.6025\paperheight);
      \node[anchor=east, font=\fontsize{140}{140}\selectfont\bfseries,
            text=white, opacity=0.08]
        at ([xshift=-15pt, yshift=0.80\paperheight]current bounding box.south) {#1};
      \node[anchor=north west]
        at (40pt, 0.88\paperheight)
        {\fontsize{13}{15}\selectfont\color{white!70}%
          CHAPTER\hspace{8pt}{\fontsize{18}{20}\selectfont\bfseries\color{white}#1}};
      \node[anchor=north west, text width=0.72\paperwidth]
        at (40pt, 0.80\paperheight)
        {\fontsize{30}{36}\selectfont\bfseries\color{white}#2};
      \draw[white!60, line width=2pt]
        (40pt, 0.645\paperheight) -- (0.42\paperwidth, 0.645\paperheight);
    }%
  \end{tikzpicture}%
  \clearpage
  \restoregeometry}

% ── Title page (theme-aware) ──
\newcommand{\maketitlepage}{%
  \pagestyle{empty}\newgeometry{paper=a4paper, margin=0pt}%
  \begin{tikzpicture}[remember picture, overlay]
    \iftoggle{sudodoc@dark}{%
      % ── DARK title page ──
      \fill[cPageBg] (current page.north west) rectangle (current page.south east);
      \fill[cAccent] (current page.north west) rectangle ([xshift=4pt]current page.south west);
      \draw[cAccent, line width=0.4pt]
        ([xshift=40pt, yshift=-0.38\paperheight]current page.north west)
        -- ([xshift=-40pt, yshift=-0.38\paperheight]current page.north east);
      \node[anchor=south east, text width=0.72\paperwidth, align=flush right]
        at ([xshift=-0.14\paperwidth, yshift=0.10\paperheight]current page.center)
        {{\fontsize{28}{34}\selectfont\bfseries\color{cTitleFg}\sudodoctitle}};
      \node[anchor=north east, text width=0.72\paperwidth, align=flush right]
        at ([xshift=-0.14\paperwidth, yshift=0.11\paperheight]current page.center)
        {{\fontsize{14}{18}\selectfont\color{cAccentLight}\sudodocsubtitle}};
      \draw[cAccent, line width=1.6pt]
        ([xshift=0.14\paperwidth, yshift=0.04\paperheight]current page.center)
        -- ([xshift=0.86\paperwidth, yshift=0.04\paperheight]current page.center);
      \node[anchor=north west, text width=0.72\paperwidth]
        at ([xshift=0.14\paperwidth, yshift=0.01\paperheight]current page.center)
        {{\fontsize{11}{14}\selectfont\color{cAccentLight}\sudodocauthor}};
      \node[anchor=north west, text width=0.72\paperwidth]
        at ([xshift=0.14\paperwidth, yshift=-0.04\paperheight]current page.center)
        {{\fontsize{10}{13}\selectfont\color{cMidGray}\sudodocinstitution}};
      \node[anchor=north west, text width=0.72\paperwidth]
        at ([xshift=0.14\paperwidth, yshift=-0.10\paperheight]current page.center)
        {{\fontsize{10}{13}\selectfont\color{cMidGray}\sudodocdate}};
      \node[anchor=south, font=\fontsize{9}{11}\selectfont, text=cMidGray]
        at ([yshift=12pt]current page.south) {i};
    }{%
      % ── LIGHT title page ──
      \fill[cLightPaper] (current page.north west) rectangle (current page.south east);
      \fill[cAccent] (current page.north west) rectangle ([xshift=4pt]current page.south west);
      \fill[cAccent]
        (current page.north west) rectangle ([yshift=-3cm]current page.north east);
      \draw[cBorder, line width=0.4pt]
        ([xshift=40pt, yshift=-0.38\paperheight]current page.north west)
        -- ([xshift=-40pt, yshift=-0.38\paperheight]current page.north east);
      \node[anchor=south east, text width=0.72\paperwidth, align=flush right]
        at ([xshift=-0.14\paperwidth, yshift=0.10\paperheight]current page.center)
        {{\fontsize{28}{34}\selectfont\bfseries\color{cLightText}\sudodoctitle}};
      \node[anchor=north east, text width=0.72\paperwidth, align=flush right]
        at ([xshift=-0.14\paperwidth, yshift=0.11\paperheight]current page.center)
        {{\fontsize{14}{18}\selectfont\color{cLightMid}\sudodocsubtitle}};
      \draw[cAccent, line width=1.6pt]
        ([xshift=0.14\paperwidth, yshift=0.04\paperheight]current page.center)
        -- ([xshift=0.86\paperwidth, yshift=0.04\paperheight]current page.center);
      \node[anchor=north west, text width=0.72\paperwidth]
        at ([xshift=0.14\paperwidth, yshift=0.01\paperheight]current page.center)
        {{\fontsize{11}{14}\selectfont\color{cLightText}\sudodocauthor}};
      \node[anchor=north west, text width=0.72\paperwidth]
        at ([xshift=0.14\paperwidth, yshift=-0.04\paperheight]current page.center)
        {{\fontsize{10}{13}\selectfont\color{cLightMid}\sudodocinstitution}};
      \node[anchor=north west, text width=0.72\paperwidth]
        at ([xshift=0.14\paperwidth, yshift=-0.10\paperheight]current page.center)
        {{\fontsize{10}{13}\selectfont\color{cLightMid}\sudodocdate}};
      \node[anchor=south, font=\fontsize{9}{11}\selectfont, text=cLightMid]
        at ([yshift=12pt]current page.south) {i};
    }%
  \end{tikzpicture}\clearpage\restoregeometry}

% ── TOC page (theme-aware) ──
\newcommand{\maketoc}{%
  \clearpage
  \newgeometry{paper=a4paper, top=25mm, bottom=25mm, left=30mm, right=25mm, headheight=0pt}%
  \thispagestyle{empty}%
  \vspace{-5mm}%
  {\fontsize{24}{28}\selectfont\bfseries\color{cTocFg}Contents}\\[6pt]%
  {\color{cAccent}\rule{0.30\textwidth}{1.2pt}}\\[14pt]%
  \setlength{\parskip}{0pt}%
  \renewcommand{\contentsname}{}%
  \tableofcontents%
  \clearpage
  \restoregeometry}

% ── Headers / Footers (theme-aware) ──
\pagestyle{fancy}\fancyhf{}
\fancyhead[L]{{\fontsize{8}{10}\selectfont\color{cHeaderFg}\leftmark}}
\fancyhead[R]{{\fontsize{8}{10}\selectfont\color{cHeaderFg}\sudodoctitle}}
\fancyfoot[C]{{\fontsize{8}{10}\selectfont\color{cFooterFg}%
    \rule{2cm}{0.3pt}\hspace{6pt}\thepage\hspace{6pt}\rule{2cm}{0.3pt}}}
\renewcommand{\headrulewidth}{0pt}
\renewcommand{\footrulewidth}{0pt}

% ── Tables (theme-aware) ──
\newcommand{\rowcolorhead}{\rowcolor{cTableHeadBg}}
\newcommand{\rowcoloralt}{\rowcolor{cTableAltBg}}
\arrayrulecolor{cTableRule}

% ── Lists (theme-aware) ──
\setitemize{itemsep=6pt, parsep=2pt, topsep=8pt, partopsep=4pt, leftmargin=18pt, labelsep=8pt}
\renewcommand{\labelitemi}{\textcolor{cBullet}{\small$\blacktriangleright$}}
\renewcommand{\labelitemii}{\textcolor{cAccent}{\raisebox{0.2ex}{\tiny$\blacksquare$}}}
\renewcommand{\labelitemiii}{\textcolor{cMidGray}{\raisebox{0.1ex}{\scriptsize$\square$}}}
\setenumerate{itemsep=6pt, parsep=2pt, topsep=8pt, partopsep=4pt, leftmargin=24pt, labelsep=8pt}
\renewcommand{\labelenumi}{\colorbox{cEnum}{\textcolor{white}{\footnotesize\bfseries\hspace{4pt}\theenumi\hspace{4pt}}}}
\renewcommand{\labelenumii}{\colorbox{cMidGray}{\textcolor{white}{\footnotesize\bfseries\hspace{4pt}\theenumii\hspace{4pt}}}}
\setdescription{itemsep=8pt, parsep=2pt, topsep=8pt, leftmargin=0pt, labelsep=12pt, font={\bfseries\color{cAccent}}}

% ── Code listings (theme-aware) ──
\lstdefinestyle{sudodoc}{
  backgroundcolor=\color{cCodeBack}, basicstyle=\ttfamily\small\color{cBodyFg},
  keywordstyle=\bfseries\color{cCodeKeyword}, stringstyle=\color{cCodeString},
  commentstyle=\itshape\color{cCodeComment}, numberstyle=\tiny\color{cMidGray},
  numbers=left, numbersep=10pt, frame=l, framerule=2pt, rulecolor=\color{cCodeKeyword},
  xleftmargin=16pt, framexleftmargin=16pt, breaklines=true, breakatwhitespace=true,
  tabsize=4, showstringspaces=false, captionpos=b, aboveskip=12pt, belowskip=6pt,
  columns=fullflexible, keepspaces=true,
}
\lstset{style=sudodoc}

