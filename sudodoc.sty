% sudodoc.sty — Clean, modern LaTeX document template
% Compile: lualatex (run TWICE for TOC + overlays)
\ProvidesPackage{sudodoc}[2026/05/13 v1.0.0 sudo-aza template]

% ── Packages ──
\RequirePackage{fontspec}
\RequirePackage{geometry}
\RequirePackage{xcolor}
\RequirePackage{tikz}
\RequirePackage{graphicx}
\RequirePackage{titlesec}
\RequirePackage{titletoc}
\RequirePackage{enumitem}
\RequirePackage{parskip}
\RequirePackage{calc}
\RequirePackage{fancyhdr}
\RequirePackage{lastpage}
\RequirePackage{booktabs}
\RequirePackage{listings}
\RequirePackage{caption}
\RequirePackage{colortbl}
\RequirePackage{multirow}
\RequirePackage{tcolorbox}
\tcbuselibrary{skins}
\RequirePackage{amsmath}
\RequirePackage{amssymb}

% ── Fonts ──
\setsansfont{Latin Modern Sans}
\setmainfont{Latin Modern Roman}
\setmonofont{Latin Modern Mono}

% ── Colors ──
\definecolor{titleDark}{HTML}{1A1A2E}
\definecolor{titleAccent}{HTML}{16213E}
\definecolor{titleRule}{HTML}{0F3460}
\definecolor{titleLight}{HTML}{E8E8E8}
\definecolor{titleMid}{HTML}{888888}
\definecolor{tableHead}{HTML}{1A1A2E}
\definecolor{tableHeadText}{HTML}{FFFFFF}
\definecolor{tableAlt}{HTML}{F0F4F8}
\definecolor{tableBorder}{HTML}{D0D8E0}
\definecolor{codeBg}{HTML}{F5F7FA}
\definecolor{codeKeyword}{HTML}{0F3460}
\definecolor{codeString}{HTML}{2E7D32}
\definecolor{codeComment}{HTML}{90A4AE}
\definecolor{quoteBg}{HTML}{F8F4F0}
\definecolor{quoteBorder}{HTML}{0F3460}
\definecolor{quoteText}{HTML}{3E3E3E}
\definecolor{bulletColor}{HTML}{0F3460}
\definecolor{enumColor}{HTML}{0F3460}

% ── User metadata (pgfkeys) ──
\newcommand{\sudodoctitle}{Your Document Title}
\newcommand{\sudodocsubtitle}{}
\newcommand{\sudodocauthor}{Author Name}
\newcommand{\sudodocinstitution}{Institution}
\newcommand{\sudodocdate}{\today}
\pgfkeys{/sudodoc/.cd,
  title/.store in=\sudodoctitle,
  subtitle/.store in=\sudodocsubtitle,
  author/.store in=\sudodocauthor,
  institution/.store in=\sudodocinstitution,
  date/.store in=\sudodocdate,
}
\newcommand{\sudodocsetup}[1]{\pgfkeys{/sudodoc/.cd,#1}}

% ── Geometry ──
\geometry{paper=a4paper, top=30mm, bottom=30mm, left=30mm, right=25mm, headheight=15pt}

% ── Section headings ──
\titleformat{\section}
  {\normalfont\Large\bfseries\color{titleDark}}
  {}{0pt}
  {\vspace{6pt}\begin{tikzpicture}[baseline=(title.base)]
     \node[anchor=west, inner sep=0pt] (title) {\insertsection};
     \draw[titleRule, line width=1.2pt]
       ([yshift=-3pt]title.south west) -- ([yshift=-3pt]title.south east);
   \end{tikzpicture}}
  [\vspace{2pt}]
\titleformat{\subsection}
  {\normalfont\large\bfseries\color{titleRule}}
  {}{0pt}
  {\hspace{4pt}\tikz[baseline=(num.base)]{
     \node[fill=titleRule, text=white, rounded corners=2pt,
           inner xsep=6pt, inner ysep=2pt,
           font=\footnotesize\bfseries] (num) {\thesubsection};}%
   \hspace{6pt}\insertsubsection}
  [\vspace{2pt}]
\titleformat{\subsubsection}
  {\normalfont\normalsize\bfseries\color{titleMid}}
  {}{0pt}
  {\hspace{14pt}{\color{titleRule}\textbullet}\hspace{8pt}\insertsubsubsection}
  [\vspace{1pt}]
\titlespacing{\section}{0pt}{24pt plus 4pt minus 2pt}{12pt plus 2pt minus 1pt}
\titlespacing{\subsection}{0pt}{18pt plus 3pt minus 1pt}{8pt plus 1pt minus 1pt}
\titlespacing{\subsubsection}{0pt}{12pt plus 2pt minus 1pt}{6pt}

% ── TOC ──
\renewcommand{\contentsname}{\vspace*{-10pt}%
  {\fontsize{24}{28}\selectfont\bfseries\color{titleDark}Contents}}
\titlecontents{section}[0pt]
  {\addvspace{14pt}\fontsize{12}{14}\selectfont\bfseries\color{titleDark}}
  {\thecontentslabel\hspace{10pt}}{}
  {\hspace{1em}\tikz[baseline=-0.5ex]{
     \draw[titleRule!40, line width=0.5pt] (0,0) -- (3cm,0);
     \node[anchor=west, font=\fontsize{10}{12}\selectfont\color{titleMid}]
       at (3.2cm,0) {\thecontentspage};}}
  \addvspace{4pt}
\titlecontents{subsection}[16pt]
  {\addvspace{6pt}\fontsize{11}{13}\selectfont\color{titleAccent}}
  {\thecontentslabel\hspace{8pt}}{}
  {\hspace{1em}\tikz[baseline=-0.5ex]{
     \draw[titleMid!40, line width=0.4pt] (0,0) -- (2.5cm,0);
     \node[anchor=west, font=\fontsize{10}{12}\selectfont\color{titleMid}]
       at (2.7cm,0) {\thecontentspage};}}
  \addvspace{2pt}
\titlecontents{subsubsection}[32pt]
  {\addvspace{3pt}\fontsize{10}{12}\selectfont\color{titleMid}}{}{}
  {\hspace{1em}\tikz[baseline=-0.5ex]{
     \draw[titleMid!25, line width=0.3pt] (0,0) -- (2cm,0);
     \node[anchor=west, font=\fontsize{9}{11}\selectfont\color{titleMid}]
       at (2.2cm,0) {\thecontentspage};}}

% ── Captions ──
\captionsetup{tableposition=top, font=small, labelfont=bf, labelsep=period, skip=8pt, belowskip=6pt}
\captionsetup[lstlisting]{font=small, labelfont=bf, labelsep=period}

% ── Chapter page ──
\newcommand{\chapterpage}[2]{%
  \clearpage\thispagestyle{empty}%
  \begin{tikzpicture}[remember picture, overlay]
    \fill[titleDark] (current page.north west) rectangle (current page.south east);
    \node[anchor=south east, font=\fontsize{160}{160}\selectfont\bfseries,
          text=white, opacity=0.06]
      at ([xshift=-20pt, yshift=20pt]current page.south east) {#1};
    \draw[titleRule, line width=0.4pt]
      ([xshift=40pt, yshift=-0.42\paperheight]current page.north west)
      -- ([xshift=-40pt, yshift=-0.42\paperheight]current page.north east);
    \node[anchor=south west, text width=0.7\paperwidth]
      at ([xshift=0.14\paperwidth, yshift=0.06\paperheight]current page.center)
      {{\fontsize{11}{13}\selectfont\color{titleMid}%
        CHAPTER\hspace{8pt}\fontsize{13}{15}\selectfont\color{titleLight}#1}};
    \node[anchor=north west, text width=0.7\paperwidth, align=flush left]
      at ([xshift=0.14\paperwidth, yshift=0.08\paperheight]current page.center)
      {{\fontsize{28}{34}\selectfont\bfseries\color{white}#2}};
    \draw[titleRule, line width=1.2pt]
      ([xshift=0.14\paperwidth, yshift=0.005\paperheight]current page.center)
      -- ([xshift=0.55\paperwidth, yshift=0.005\paperheight]current page.center);
  \end{tikzpicture}\clearpage}

% ── Title page ──
\newcommand{\maketitlepage}{%
  \pagestyle{empty}\newgeometry{paper=a4paper, margin=0pt}%
  \begin{tikzpicture}[remember picture, overlay]
    \fill[titleDark] (current page.north west) rectangle (current page.south east);
    \fill[titleRule] (current page.north west) rectangle ([xshift=4pt]current page.south west);
    \draw[titleRule, line width=0.4pt]
      ([xshift=40pt, yshift=-0.38\paperheight]current page.north west)
      -- ([xshift=-40pt, yshift=-0.38\paperheight]current page.north east);
    \node[anchor=south east, text width=0.72\paperwidth, align=flush right]
      at ([xshift=-0.14\paperwidth, yshift=0.10\paperheight]current page.center)
      {{\fontsize{28}{34}\selectfont\bfseries\color{white}\sudodoctitle}};
    \node[anchor=north east, text width=0.72\paperwidth, align=flush right]
      at ([xshift=-0.14\paperwidth, yshift=0.11\paperheight]current page.center)
      {{\fontsize{14}{18}\selectfont\color{titleLight}\sudodocsubtitle}};
    \draw[titleRule, line width=1.6pt]
      ([xshift=0.14\paperwidth, yshift=0.04\paperheight]current page.center)
      -- ([xshift=0.86\paperwidth, yshift=0.04\paperheight]current page.center);
    \node[anchor=north west, text width=0.72\paperwidth]
      at ([xshift=0.14\paperwidth, yshift=0.01\paperheight]current page.center)
      {{\fontsize{11}{14}\selectfont\color{titleLight}\sudodocauthor}};
    \node[anchor=north west, text width=0.72\paperwidth]
      at ([xshift=0.14\paperwidth, yshift=-0.04\paperheight]current page.center)
      {{\fontsize{10}{13}\selectfont\color{titleMid}\sudodocinstitution}};
    \node[anchor=north west, text width=0.72\paperwidth]
      at ([xshift=0.14\paperwidth, yshift=-0.10\paperheight]current page.center)
      {{\fontsize{10}{13}\selectfont\color{titleMid}\sudodocdate}};
    \node[anchor=south, font=\fontsize{9}{11}\selectfont, text=titleMid]
      at ([yshift=12pt]current page.south) {i};
  \end{tikzpicture}\clearpage\restoregeometry}

% ── TOC page ──
\newcommand{\maketoc}{%
  \thispagestyle{empty}%
  \begin{tikzpicture}[remember picture, overlay]
    \fill[titleDark] (current page.north west) rectangle ([yshift=-6pt]current page.north east);
    \fill[titleRule] ([xshift=50pt]current page.north west) rectangle ([xshift=54pt]current page.south west);
  \end{tikzpicture}\vspace{18pt}\hspace{22pt}\tableofcontents\clearpage}

% ── Headers / Footers ──
\pagestyle{fancy}\fancyhf{}
\fancyhead[L]{{\fontsize{8}{10}\selectfont\color{titleMid}\leftmark}}
\fancyhead[R]{{\fontsize{8}{10}\selectfont\color{titleMid}\sudodoctitle}}
\fancyfoot[C]{{\fontsize{8}{10}\selectfont\color{titleMid}%
    \rule{2cm}{0.3pt}\hspace{6pt}\thepage\hspace{6pt}\rule{2cm}{0.3pt}}}
\renewcommand{\headrulewidth}{0pt}
\renewcommand{\footrulewidth}{0pt}

% ── Tables ──
\newcommand{\rowcolorhead}{\rowcolor{tableHead}}
\newcommand{\rowcoloralt}{\rowcolor{tableAlt}}
\arrayrulecolor{tableBorder}

% ── Lists ──
\setitemize{itemsep=6pt, parsep=2pt, topsep=8pt, partopsep=4pt, leftmargin=18pt, labelsep=8pt}
\renewcommand{\labelitemi}{\textcolor{bulletColor}{\small$\blacktriangleright$}}
\renewcommand{\labelitemii}{\textcolor{titleRule}{\raisebox{0.2ex}{\tiny$\blacksquare$}}}
\renewcommand{\labelitemiii}{\textcolor{titleMid}{\raisebox{0.1ex}{\scriptsize$\square$}}}
\setenumerate{itemsep=6pt, parsep=2pt, topsep=8pt, partopsep=4pt, leftmargin=24pt, labelsep=8pt}
\renewcommand{\labelenumi}{\colorbox{enumColor}{\textcolor{white}{\footnotesize\bfseries\hspace{4pt}\theenumi\hspace{4pt}}}}
\renewcommand{\labelenumii}{\colorbox{titleMid}{\textcolor{white}{\footnotesize\bfseries\hspace{4pt}\theenumii\hspace{4pt}}}}
\setdescription{itemsep=8pt, parsep=2pt, topsep=8pt, leftmargin=0pt, labelsep=12pt, font={\bfseries\color{titleRule}}}

% ── Code listings ──
\lstdefinestyle{sudodoc}{
  backgroundcolor=\color{codeBg}, basicstyle=\ttfamily\small\color{titleDark},
  keywordstyle=\bfseries\color{codeKeyword}, stringstyle=\color{codeString},
  commentstyle=\itshape\color{codeComment}, numberstyle=\tiny\color{titleMid},
  numbers=left, numbersep=10pt, frame=l, framerule=2pt, rulecolor=\color{codeKeyword},
  xleftmargin=16pt, framexleftmargin=16pt, breaklines=true, breakatwhitespace=true,
  tabsize=4, showstringspaces=false, captionpos=b, aboveskip=12pt, belowskip=6pt,
  columns=fullflexible, keepspaces=true,
}
\lstset{style=sudodoc}

% ── Blockquotes ──
\newtcolorbox{blockquote}{
  enhanced, colback=quoteBg, colframe=quoteBorder,
  boxrule=0pt, leftrule=3pt, arc=0pt, outer arc=0pt,
  left=14pt, right=10pt, top=10pt, bottom=10pt,
  fontupper=\itshape\color{quoteText}\small,
  before upper={\tikz[baseline=-0.5ex]{\node[font=\Large\color{quoteBorder}] at (0,0) {``};}\hspace{4pt}},
  after upper={\hspace{4pt}\tikz[baseline=-0.5ex]{\node[font=\Large\color{quoteBorder}] at (0,0) {''};}},
}

\endinput
